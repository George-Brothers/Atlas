# atlas environment variables.
# Copy to `.env.local` for local dev and set the same keys in Vercel for deploy.
# `.env*` is gitignored (except this example) — never commit real secrets.

# ── Auth (required; the app is LOCKED / fail-closed until BOTH are set) ────────

# Secret used to encrypt & sign the session cookie (iron-session). MUST be >= 32
# chars. Generate one, e.g.:  openssl rand -base64 48
SESSION_SECRET=

# scrypt hash of the single dashboard password (NEVER the plaintext password).
# Generate with:  node scripts/hash-password.mjs   (then paste the printed line)
# Format: scrypt$<N>$<r>$<p>$<saltHex>$<keyHex>
DASHBOARD_PASSWORD_HASH=

# ── Database (required once you provision Neon; unused by Phase 0 runtime) ─────

# Neon Postgres connection string (serverless driver). Used by Drizzle for
# `drizzle-kit push`/`migrate` and by the app at request time in later phases.
DATABASE_URL=

# ── AI provider (required at runtime for quiz grading; see lib/ai) ────────────

# The app calls DeepSeek's API DIRECTLY via @ai-sdk/deepseek (lib/ai/index.ts) —
# no Vercel AI Gateway. There is exactly ONE live call: the strict free-text
# quiz grader (lib/ai/grader.ts, cheap slot → deepseek-v4-flash). The app builds and
# all deterministic logic runs without a credential; only submitting a free-text
# quiz answer (and `npm run eval:grader`) needs one. Curriculum/lesson content is
# pre-seeded, never live-generated.

# Direct DeepSeek API key (https://platform.deepseek.com/api_keys). Fail-closed:
# the grader refuses if this is unset.
DEEPSEEK_API_KEY=

# Optional overrides for the "strong" / "cheap" model slots (see lib/ai/index.ts).
# The cheap/grader slot takes any DeepSeek model id (deepseek-v4-flash |
# deepseek-v4-pro). The strong slot has no live provider yet — a direct
# Google/Gemini provider lands with vision.
# AI_CHEAP_MODEL=deepseek-v4-flash
# AI_STRONG_MODEL=gemini-2.5-flash

# ── Embeddings / retrieval (M4; direct OpenAI, no gateway; see lib/ai/embeddings) ─

# Direct OpenAI API key (https://platform.openai.com/api-keys). Used ONLY for
# embeddings: `text-embedding-3-small` (native 1536 dims, matches the fixed
# source_chunk.embedding vector(1536) column). Fail-closed: ingestion
# (`npm run db:ingest`) and the grounded tutor's query step refuse without it.
# The DeepSeek key above still powers tutor ANSWER generation (deepseek-v4-flash).
OPENAI_API_KEY=
